# Generated from templates/lhm/lhm.rb.tmpl — do not edit directly.
# Run: gh workflow run bump-formula.yaml -f formula=lhm

class Lhm < Formula
  desc "Merges global and repo lefthook configs"
  homepage "https://github.com/block/lhm"
  license "Apache-2.0"
  version "{{.version}}"

  on_macos do
    if Hardware::CPU.arm?
      url "https://github.com/block/lhm/releases/download/{{.tag}}/lhm-aarch64-apple-darwin.bz2"
      sha256 "{{ sha256 .assets "lhm-aarch64-apple-darwin" }}"
    else
      url "https://github.com/block/lhm/releases/download/{{.tag}}/lhm-x86_64-apple-darwin.bz2"
      sha256 "{{ sha256 .assets "lhm-x86_64-apple-darwin" }}"
    end
  end

  on_linux do
    if Hardware::CPU.arm?
      url "https://github.com/block/lhm/releases/download/{{.tag}}/lhm-aarch64-unknown-linux-gnu.bz2"
      sha256 "{{ sha256 .assets "lhm-aarch64-unknown-linux-gnu" }}"
    else
      url "https://github.com/block/lhm/releases/download/{{.tag}}/lhm-x86_64-unknown-linux-gnu.bz2"
      sha256 "{{ sha256 .assets "lhm-x86_64-unknown-linux-gnu" }}"
    end
  end

  def install
    # bz2 is auto-extracted by Homebrew; the resulting file needs to be renamed
    binary = buildpath.children.first
    binary.chmod 0755
    bin.install binary => "lhm"
  end

  test do
    system bin/"lhm", "--help"
  end
end
