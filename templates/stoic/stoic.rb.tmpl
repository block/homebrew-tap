# Generated from templates/stoic/stoic.rb.tmpl — do not edit directly.
# Run: gh workflow run bump-formula.yaml -f formula=stoic

class Stoic < Formula
  desc "CLI tool for Android investigations"
  homepage "https://github.com/block/stoic"
  url "https://github.com/block/stoic/releases/download/{{.tag}}/stoic-release.tar.gz"
  sha256 "{{ sha256 .assets "stoic-release" }}"
  license "Apache-2.0"
  version "{{.version}}"

  def install
    libexec.install Dir["*"]

    # Use native binary for macOS ARM64, JVM version for everything else
    if OS.mac? && Hardware::CPU.arm?
      bin.install_symlink libexec/"bin/darwin-arm64/stoic"
    else
      bin.install_symlink libexec/"bin/jvm/stoic"
    end
  end

  test do
    system "#{bin}/stoic", "--help"
  end
end
